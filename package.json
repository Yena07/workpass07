{
  "name": "workpass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "chain": "npx hardhat node",
    "deploy": "npx hardhat ignition deploy ignition/modules/WorkPass.ts --network localhost && node scripts/export-addresses.mjs",
    "deploy:sepolia": "npx hardhat ignition deploy ignition/modules/WorkPass.ts --network sepolia --reset && node scripts/export-addresses.mjs sepolia",
    "compile": "npx hardhat compile"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@upstash/redis": "^1.38.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "hardhat": "^3.5.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "type": "module"
}
